# ── Whitelist: the repo ships only the native app and the README ──
# Ignore everything at the root, then re-include what's needed to
# build/run Chud. Local-only stuff (legacy Python app, design handoffs,
# build artifacts, personal tools) never gets tracked.
/*
!/native/
!/docs/
!/relay-worker/
!/runes-worker/
!/skins-worker/
!/tools/
!/README.md
!/.gitignore
!/.gitattributes

# Relay worker build output (wasm + wrangler artifacts)
relay-worker/target/
relay-worker/build/
relay-worker/.wrangler/

# Runes worker (JS) local-only artifacts
runes-worker/node_modules/
runes-worker/.wrangler/

# ── Inside native/: build output + local-only files ──
native/target/
native/**/target/
# Alternate release build dir (used to build while the main exe is locked)
native/target-rel/
**/*.rs.bk
native/ui/node_modules/
native/src-tauri/gen/schemas/
native/ui.hextech.bak/

# Machine-specific cargo config (redirects target-dir off OneDrive)
native/.cargo/

# Dev-only helpers and internal notes (not needed to build or run)
native/make_ico.py
native/README.md
native/ui/README.md

# cslol-dll.dll is a DMCA-sensitive redistribution of Riot's WAD hook and is
# NEVER committed — the user supplies their own copy. hashes.game.txt (207 MB)
# is downloaded at runtime from CommunityDragon, never committed.
native/src-tauri/resources/cslol-tools/cslol-dll.dll
**/hashes.game.txt

# ── Editor / OS noise (applies everywhere) ──
__pycache__/
*.py[cod]
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Pengu Loader rebrand backups + runtime logs (never bundle/commit)
native/src-tauri/resources/pengu-loader/*.rosebak
native/src-tauri/resources/pengu-loader/*.log

# Local handoff doc — contains secrets, never commit
CHUD-HANDOFF.md
