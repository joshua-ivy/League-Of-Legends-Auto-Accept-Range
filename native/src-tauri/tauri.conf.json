{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chud",
  "version": "1.2.0",
  "identifier": "com.leagueofandi.tools",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chud",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 660,
        "resizable": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png", "icons/icon.ico"]
  }
}
