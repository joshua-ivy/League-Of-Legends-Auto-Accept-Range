{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chud",
  "version": "2.3.0",
  "identifier": "com.leagueofandi.tools",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chud",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 660,
        "resizable": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0RUZFQjhFNzk1OEUxRjEKUldUeDRWaDVqdXZ2dEdBTm95UEE3R21FNFdMSnlwODZSM3dycmpKOFRndWJ0V01kRE16amdtd2wK",
      "endpoints": [
        "https://github.com/ChudTonic/League-Of-Legends-Auto-Accept-Range/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/assets",
      "resources/pengu-loader",
      "resources/CREDITS.md",
      "resources/cslol-tools/mod-tools.exe",
      "resources/cslol-tools/wad-extract.exe",
      "resources/cslol-tools/wad-make.exe",
      "resources/announcer-studio"
    ]
  }
}
