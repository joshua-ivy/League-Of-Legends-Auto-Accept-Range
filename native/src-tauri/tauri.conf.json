{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chud",
  "version": "3.0.0",
  "identifier": "com.leagueofandi.tools",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chud",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 660,
        "resizable": true,
        "decorations": true,
        "theme": "Dark"
      },
      {
        "label": "overlay",
        "title": "Chud Skin Picker",
        "url": "overlay.html",
        "width": 460,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' data: https://raw.communitydragon.org https://cdn.communitydragon.org https://chud-skins.jivy26.workers.dev; media-src 'self' data: blob:; frame-src https://www.youtube-nocookie.com; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0RUZFQjhFNzk1OEUxRjEKUldUeDRWaDVqdXZ2dEdBTm95UEE3R21FNFdMSnlwODZSM3dycmpKOFRndWJ0V01kRE16amdtd2wK",
      "endpoints": [
        "https://github.com/ChudTonic/League-Of-Legends-Auto-Accept-Range/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/assets",
      "resources/CREDITS.md",
      "resources/cslol-tools/mod-tools.exe",
      "resources/cslol-tools/wad-extract.exe",
      "resources/cslol-tools/wad-make.exe",
      "resources/announcer-studio"
    ]
  }
}
